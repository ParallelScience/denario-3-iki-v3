**Code Explanation:**

This script performs Latent Class Analysis (LCA) on the joint distribution of current (`QEA_2`) and expected (`QEB_2`) job security impacts. Since standard Python libraries (like `scikit-learn`) do not include a built-in LCA model for categorical data, a highly optimized custom Expectation-Maximization (EM) algorithm is implemented. 

The responses are mapped to 6 distinct nominal categories (0 to 5), where 5 represents the "Not sure" or missing responses, treating them as a distinct category as requested. The script evaluates models with 2 to 6 latent classes, calculating the Log-Likelihood, Bayesian Information Criterion (BIC), and Entropy for each. 

The best model is automatically selected based on the minimum BIC. To aid interpretability, the latent classes are sorted in descending order based on their average probability of reporting a positive impact. Finally, the script prints the conditional response probabilities for the chosen model, saves a dual-axis plot of BIC and Entropy, and appends the individual class assignments to the dataset, saving it as a new CSV file.

**Python Code:**

```python
import sys
import os
sys.path.insert(0, os.path.abspath("codebase"))
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from scipy.special import logsumexp
import time

def run_lca(data, n_classes, n_init=20, max_iter=1000, tol=1e-7):
    """
    Run Latent Class Analysis using an optimized EM algorithm.
    data: array of shape (N, M) with integer categories 0 to C_max-1.
    """
    N, M = data.shape
    C_max = int(np.max(data) + 1)
    
    # Precompute one-hot encodings for each variable to speed up the M-step
    one_hots = [np.eye(C_max)[data[:, m]] for m in range(M)]
    
    best_ll = -np.inf
    best_model = None
    
    for init in range(n_init):
        # Initialize parameters with Dirichlet distribution
        pi = np.random.dirichlet(np.ones(n_classes))
        theta = np.random.dirichlet(np.ones(C_max), size=(n_classes, M))
        
        ll_old = -np.inf
        for iteration in range(max_iter):
            # E-step
            log_prob_y_given_c = np.zeros((N, n_classes))
            for m in range(M):
                # Vectorized extraction of probabilities for observed categories
                log_prob_y_given_c += np.log(theta[:, m, data[:, m]].T + 1e-15)
                
            log_joint = np.log(pi + 1e-15) + log_prob_y_given_c
            log_marginal = logsumexp(log_joint, axis=1)
            ll = np.sum(log_marginal)
            
            # Calculate posterior probabilities (gamma)
            gamma = np.exp(log_joint - log_marginal[:, np.newaxis])
            
            # M-step
            N_c = np.sum(gamma, axis=0)
            pi = N_c / N
            
            for m in range(M):
                # Fast matrix multiplication to compute weighted counts
                counts = (one_hots[m].T @ gamma).T
                # Update theta with Laplace smoothing to prevent zero probabilities
                theta[:, m, :] = (counts + 1e-6) / (N_c[:, np.newaxis] + C_max * 1e-6)
                
            if np.abs(ll - ll_old) < tol:
                break
            ll_old = ll
            
        if ll > best_ll:
            best_ll = ll
            best_model = {
                'pi': pi,
                'theta': theta,
                'gamma': gamma,
                'll': ll,
                'n_iter': iteration
            }
            
    return best_model

if __name__ == '__main__':
    np.random.seed(42)
    
    # Load cleaned dataset
    data_path = os.path.join('data', 'cleaned_dataset.csv')
    df = pd.read_csv(data_path, low_memory=False)
    
    if 'QEA_2' not in df.columns or 'QEB_2' not in df.columns:
        raise ValueError("QEA_2 or QEB_2 not found in the dataset.")
        
    # Map values to 0-5
    # -2.0 -> 0, -1.0 -> 1, 0.0 -> 2, 1.0 -> 3, 2.0 -> 4, NaN -> 5 (Not sure / Missing)
    mapping = {-2.0: 0, -1.0: 1, 0.0: 2, 1.0: 3, 2.0: 4}
    y1 = df['QEA_2'].map(mapping).fillna(5).astype(int).values
    y2 = df['QEB_2'].map(mapping).fillna(5).astype(int).values
    data = np.column_stack((y1, y2))
    
    N, M = data.shape
    C_max = 6
    
    bics = []
    entropies = []
    norm_entropies = []
    models = {}
    
    print("Running Latent Class Analysis for 2 to 6 classes...")
    for k in range(2, 7):
        model = run_lca(data, k, n_init=20, max_iter=1000)
        models[k] = model
        
        # Calculate BIC
        n_params = (k - 1) + k * M * (C_max - 1)
        bic = n_params * np.log(N) - 2 * model['ll']
        bics.append(bic)
        
        # Calculate Entropy
        gamma = model['gamma']
        entropy = -np.sum(gamma * np.log(gamma + 1e-15))
        norm_entropy = 1 - entropy / (N * np.log(k))
        
        entropies.append(entropy)
        norm_entropies.append(norm_entropy)
        
        print(f"Class {k}: Log-Likelihood = {model['ll']:.2f}, BIC = {bic:.2f}, Entropy = {entropy:.2f}, Norm Entropy = {norm_entropy:.4f}")
        
    # Save model statistics
    stats_df = pd.DataFrame({
        'Classes': range(2, 7),
        'BIC': bics,
        'Entropy': entropies,
        'Normalized_Entropy': norm_entropies
    })
    stats_path = os.path.join('data', 'lca_model_statistics.csv')
    stats_df.to_csv(stats_path, index=False)
    print(f"\nModel statistics saved to {stats_path}")
    
    # Plot BIC and Entropy
    plt.rcParams['text.usetex'] = False
    fig, ax1 = plt.subplots(figsize=(8, 5))

    color = 'tab:blue'
    ax1.set_xlabel('Number of Classes')
    ax1.set_ylabel('BIC', color=color)
    ax1.plot(range(2, 7), bics, marker='o', color=color, label='BIC')
    ax1.tick_params(axis='y', labelcolor=color)

    ax2 = ax1.twinx()
    color = 'tab:red'
    ax2.set_ylabel('Entropy', color=color)
    ax2.plot(range(2, 7), entropies, marker='s', color=color, label='Entropy')
    ax2.tick_params(axis='y', labelcolor=color)

    plt.title('LCA Model Selection: BIC and Entropy by Number of Classes')
    fig.tight_layout()
    
    timestamp = int(time.time())
    plot_filename = os.path.join('data', f"lca_bic_entropy_1_{timestamp}.png")
    plt.savefig(plot_filename, dpi=300)
    print(f"Plot saved to {plot_filename}")
    plt.close()
    
    # Select best model based on minimum BIC
    best_k = range(2, 7)[np.argmin(bics)]
    best_model = models[best_k]
    
    # Sort classes by probability of positive impact (categories 3 and 4) to aid interpretation
    pos_prob = np.sum(best_model['theta'][:, :, 3:5], axis=(1, 2))
    sort_idx = np.argsort(-pos_prob)
    
    best_model['pi'] = best_model['pi'][sort_idx]
    best_model['theta'] = best_model['theta'][sort_idx]
    best_model['gamma'] = best_model['gamma'][:, sort_idx]
    
    cat_names = ["Significantly negative", "Slightly negative", "No impact", "Slightly positive", "Significantly positive", "Not sure"]
    var_names = ["Current Impact (QEA_2)", "Expected Impact (QEB_2)"]

    print(f"\nChosen class solution: {best_k} classes (based on minimum BIC)")
    print("-" * 60)
    print("Class Sizes (Prior Probabilities):")
    for c in range(best_k):
        print(f"Class {c+1}: {best_model['pi'][c]:.4f}")

    print("\nConditional Response Probabilities:")
    for c in range(best_k):
        print(f"\n--- Class {c+1} (Size: {best_model['pi'][c]:.2%}) ---")
        for m in range(2):
            print(f"  {var_names[m]}:")
            for cat in range(6):
                prob = best_model['theta'][c, m, cat]
                print(f"    {cat_names[cat]}: {prob:.4f}")
                
    # Save class assignments
    class_assignments = np.argmax(best_model['gamma'], axis=1) + 1 # 1-indexed
    df['LCA_Class'] = class_assignments
    
    output_path = os.path.join('data', 'cleaned_dataset_with_classes.csv')
    df.to_csv(output_path, index=False)
    print(f"\nClass membership assignments saved to {output_path}")
```

