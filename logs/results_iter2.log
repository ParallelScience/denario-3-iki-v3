                print("  " + col_labels[j] + ": " + str(round(val, 4)))
        plt.figure(figsize=(14, 6))
        sns.heatmap(heatmap_data, annot=True, cmap='Blues', xticklabels=col_labels, yticklabels=row_labels, fmt=".2f")
