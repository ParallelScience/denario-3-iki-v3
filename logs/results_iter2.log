engineer (to main_cmbagent_chat):

**Code Explanation:**

The script performs Exploratory Factor Analysis (EFA) on the 16 binary `QHD` emotional attitude items to extract "Positive Affect" and "Negative Affect" factors. 
1. **Tetrachoric Correlation**: Since the items are binary, Pearson correlation is inappropriate. The script computes a tetrachoric correlation matrix using a robust trigonometric approximation (Digby, 1983).
2. **Iterative EFA**: It uses the `factor_analyzer` package to perform EFA with `minres` extraction and `oblimin` (oblique) rotation. Items with communality < 0.3 or cross-loadings > 0.3 are iteratively flagged and dropped to ensure distinct, well-defined factors.
3. **Factor Identification**: The script identifies which factor represents "Positive Affect" by checking the correlation of the factor scores with the first item (`QHD_1`, which corresponds to "Optimistic").
4. **McDonald's Omega**: It computes McDonald's Omega for each extracted subscale using the absolute factor loadings and uniquenesses (1 - communality) to assess internal reliability.
5. **Factor Scores**: Factor scores are computed using the Thurstone regression method ($Scores = Z \cdot R^{-1} \cdot L$) and saved to the dataset. If the factors are highly correlated ($|r| > 0.5$), an additional composite `AI_Sentiment` spectrum is created.

**Python Code:**

```python
import sys
import os
import pandas as pd
import numpy as np
import math

try:
    from factor_analyzer import FactorAnalyzer
except ImportError:
    print("ModuleNotFoundError: No module named 'factor_analyzer'")
    print("Please install factor_analyzer package.")
    sys.exit(1)

def tetrachoric_corr(x, y):
    """
    Computes the tetrachoric correlation between two binary variables
    using the Digby (1983) trigonometric approximation.
    """
    valid = ~(np.isnan(x) | np.isnan(y))
    x_val = x[valid]
    y_val = y[valid]
    
    if len(np.unique(x_val)) < 2 or len(np.unique(y_val)) < 2:
        return 0.0
        
    crosstab = pd.crosstab(x_val, y_val)
    if crosstab.shape != (2, 2):
        corr = np.corrcoef(x_val, y_val)[0, 1]
        return corr if not np.isnan(corr) else 0.0
        
    a = crosstab.iloc[0, 0]
    b = crosstab.iloc[0, 1]
    c = crosstab.iloc[1, 0]
    d = crosstab.iloc[1, 1]
    
    # Yates correction to prevent division by zero
    if a == 0 or b == 0 or c == 0 or d == 0:
        a += 0.5
        b += 0.5
        c += 0.5
        d += 0.5
        
    ratio = (a * d) / (b * c)
    r = math.cos(math.pi / (1 + math.sqrt(ratio)))
    return r

def get_tetrachoric_matrix(df):
    """
    Computes the pairwise tetrachoric correlation matrix for a dataframe of binary items.
    """
    cols = df.columns
    n = len(cols)
    mat = np.ones((n, n))
    for i in range(n):
        for j in range(i+1, n):
            r = tetrachoric_corr(df[cols[i]], df[cols[j]])
            mat[i, j] = r
            mat[j, i] = r
    return pd.DataFrame(mat, index=cols, columns=cols)

def main():
    data_dir = "data/"
    file_path = os.path.join(data_dir, "processed_data.csv")
    
    print("Loading processed dataset...")
    df = pd.read_csv(file_path, low_memory=False)
    
    qhd_cols = [c for c in df.columns if c.startswith('QHD_')]
    print("Found " + str(len(qhd_cols)) + " QHD items.")
    
    current_items = qhd_cols.copy()
    iteration = 1
    
    while True:
        print("\n--- EFA Iteration " + str(iteration) + " ---")
        df_efa = df[current_items].dropna()
        print("Using " + str(len(df_efa)) + " rows for EFA after dropping NaNs.")
        
        print("Computing tetrachoric correlation matrix...")
        tetra_corr = get_tetrachoric_matrix(df_efa)
        
        print("Performing EFA with 2 factors and oblimin rotation...")
        fa = FactorAnalyzer(n_factors=2, rotation='oblimin', is_corr_matrix=True, method='minres')
        fa.fit(tetra_corr)
        
        loadings = fa.loadings_
        communalities = fa.get_communalities()
        
        loadings_df = pd.DataFrame(loadings, index=current_items, columns=['Factor1', 'Factor2'])
        loadings_df['Communality'] = communalities
        
        print(loadings_df.round(3).to_string())
        
        drop_items = []
        for item in current_items:
            comm = loadings_df.loc[item, 'Communality']
            l1 = abs(loadings_df.loc[item, 'Factor1'])
            l2 = abs(loadings_df.loc[item, 'Factor2'])
            
            if comm < 0.3:
                drop_items.append(item)
            elif l1 > 0.3 and l2 > 0.3:
                drop_items.append(item)
                
        if not drop_items:
            print("No items to drop. EFA converged.")
            break
            
        print("Flagged items to drop (communality < 0.3 or cross-loadings > 0.3): " + str(drop_items))
        current_items = [item for item in current_items if item not in drop_items]
        if len(current_items) < 4:
            print("Too few items left. Stopping dropping.")
            break
        iteration += 1

    factor_corr = fa.phi_[0, 1] if hasattr(fa, 'phi_') and fa.phi_ is not None else 0.0
    print("\nFactor correlation (Phi): " + str(round(factor_corr, 3)))
    
    print("\nComputing factor scores...")
    R_inv = np.linalg.inv(tetra_corr.values)
    W = R_inv @ loadings
    
    std = df[current_items].std()
    std = std.replace(0, 1.0)
    Z = (df[current_items] - df[current_items].mean()) / std
    Z = Z.fillna(0)
    scores = Z.values @ W
    
    if qhd_cols[0] in current_items:
        ref_item = qhd_cols[0]
    else:
        ref_item = current_items[0]
        
    corr_f1 = np.corrcoef(scores[:, 0], df[ref_item].fillna(0))[0, 1]
    corr_f2 = np.corrcoef(scores[:, 1], df[ref_item].fillna(0))[0, 1]
    
    if corr_f1 > corr_f2:
        pos_idx, neg_idx = 0, 1
    else:
        pos_idx, neg_idx = 1, 0
        
    df['Positive_Affect'] = scores[:, pos_idx]
    df['Negative_Affect'] = scores[:, neg_idx]
    
    print("Positive Affect assigned to Factor " + str(pos_idx + 1))
    print("Negative Affect assigned to Factor " + str(neg_idx + 1))
    
    factor1_items = loadings_df[loadings_df['Factor1'].abs() > loadings_df['Factor2'].abs()].index.tolist()
    factor2_items = loadings_df[loadings_df['Factor2'].abs() > loadings_df['Factor1'].abs()].index.tolist()
    
    pos_items = factor1_items if pos_idx == 0 else factor2_items
    neg_items = factor2_items if pos_idx == 0 else factor1_items
    
    def compute_omega(items, f_idx):
        if not items: return 0.0
        l = np.abs(loadings_df.loc[items, loadings_df.columns[f_idx]].values)
        c = loadings_df.loc[items, 'Communality'].values
        u = 1 - c
        return (np.sum(l)**2) / ((np.sum(l)**2) + np.sum(u))
        
    omega_pos = compute_omega(pos_items, pos_idx)
    omega_neg = compute_omega(neg_items, neg_idx)
    
    print("\n--- McDonald's Omega ---")
    print("Positive Affect Omega: " + str(round(omega_pos, 3)))
    print("Negative Affect Omega: " + str(round(omega_neg, 3)))
    
    print("\n--- Factor Scores Descriptive Statistics ---")
    if factor_corr < -0.5 or factor_corr > 0.5:
        print("Factors are highly correlated. Creating a single 'AI_Sentiment' spectrum.")
        df['AI_Sentiment'] = df['Positive_Affect'] - df['Negative_Affect']
        print(df[['Positive_Affect', 'Negative_Affect', 'AI_Sentiment']].describe().round(3).to_string())
    else:
        print(df[['Positive_Affect', 'Negative_Affect']].describe().round(3).to_string())
        
    out_path = os.path.join(data_dir, "processed_data.csv")
    df.to_csv(out_path, index=False)
    print("\nDataset with factor scores saved to " + out_path)

if __name__ == '__main__':
    main()
```

