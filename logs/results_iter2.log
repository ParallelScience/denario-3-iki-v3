        plt.title('Class-Conditional Item-Response Probabilities')
        plt.xticks(rotation=90, ha='center', fontsize=9)
        plt.tight_layout()
        heatmap_path = os.path.join(data_dir, "lca_heatmap_2_" + str(timestamp) + ".png")
