                for qkb_val in [X_pred['QKB_Index'].min(), X_pred['QKB_Index'].median(), X_pred['QKB_Index'].max()]:
                    X_sim_single = pd.DataFrame({'QKB_Index': [qkb_val], 'QGO_Index': [qgo_mean]})
