    print("\n--- 2. Class-Conditional Item-Response Probabilities ---")
    if 'LCA_Class' in df.columns and not df['LCA_Class'].isna().all():
        categories = [-2.0, -1.0, 0.0, 1.0, 2.0]
        cat_labels = ['Sig. Neg', 'Slight Neg', 'No Impact', 'Slight Pos', 'Sig. Pos']
        heatmap_data = []
