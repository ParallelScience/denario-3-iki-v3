    if "using in some" in s or "limited" in s or "pockets" in s: return 3
    if "widely" in s or "scaling" in s or "multiple" in s: return 4
    if "transforming" in s or "core" in s or "everywhere" in s: return 5
    try:
        v = float(s)
        if 1 <= v <= 5: return v
    except ValueError:
        pass
    return np.nan

